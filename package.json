{
  "name": "cerbos-setup-action",
  "private": true,
  "description": "A GitHub action to setup Cerbos and Cerbosctl binaries",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.2"
  },
  "scripts": {
    "all:parallel": "concurrently --group --prefix=none",
    "build": "rm -rf dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "eslint:run": "NODE_OPTIONS=--max-old-space-size=3072 eslint --max-warnings=0",
    "lint": "pnpm run all:parallel 'pnpm:lint:check:*'",
    "lint:check:eslint": "pnpm run eslint:run src tests",
    "lint:check:prettier": "prettier --check src tests",
    "lint:fix": "pnpm run lint:fix:eslint && pnpm run lint:fix:prettier",
    "lint:fix:eslint": "pnpm run eslint:run --fix src tests",
    "lint:fix:prettier": "prettier --write src tests",
    "test": "glob-bin -c \"node --import tsx --no-warnings --test\" \"./tests/**/*.test.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cerbos/cerbos-setup-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Cerbos",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "3.0.1",
    "cerbos-actions-common": "github:cerbos/cerbos-actions-common#0.0.30",
    "https-proxy-agent": "9.1.0",
    "octokit": "5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "25.9.2",
    "concurrently": "9.2.1",
    "eslint": "10.4.1",
    "glob-bin": "1.1.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "rollup": "4.61.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
